# UZArchipelago run control file.
# This overrides the behaviour of the scanner and check-placer based on actor
# types.
#
# Available directives are:
#
#
#     require <map> <checksum> ;
#
# This GZAPRC will be loaded only if the given map is present, and has the given
# checksum. This can be used to make GZAPRCs specific to a certain megawad load
# only if that megawad is also loaded.
# You can specify multiple require lines, in which case the GZAPRC will be loaded
# if any of them match.
#
#
#     category <cat> : <list of classes> ;
#
# Assign the listed classes to the given category. Any category can be specified,
# including ones not otherwise known to the scanner -- they will be passed through
# to the apworld as is. This can be used to add objects to the scan that would
# normally be skipped, or change the category of objects.
#
# Some categories have special handling, such as 'key', 'maprevealer', 'weapon',
# and all 'ap_' categories; see doc/glossary.md for a complete list.
#
# A category of "none" will exclude something from the scan entirely, even if it
# would normally have been included.
#
# As a special case, a category of ".replaceonly" means the item/location should
# not be included in the logic file, but during gameplay, it *is* a valid target
# for replacement by a check. This is primarily useful with manually placed
# checks.
#
#
#     typename <type> : <list of classes> ;
#
# When scanning anything in the list, report it as being <type> rather than
# whatever its actual type is. The check will be named after that type rather
# than whatever was actually scanned, and the given type, not the original item,
# will be added to the item pool.
#
#
#     scanner {
#       maps <list of maps to start scanning at>;
#       skip <list of maps to skip>;
#       prune <list of maps to prune entirely>;
#       recurse <true|false>;
#       clusters <true|false>;
#     }
#
# Set defaults for the scanner.
# These are the same as the ap_scan_* CVARs without the ap_scan_ prefix.
#
#
#    prereqs {
#      all: <prereqs for all maps>;
#      actor <ActorType> ...: <prereqs for maps with those actors>;
#      map <MAPxx> ...: <prereqs for those maps>
#    }
#
# Add custom logical access prerequisites, on a per-level basis, either to all
# levels, to specific named levels, or to levels containing certain actors. This
# is a convenient way to, e.g., declare that if a level contains shotgunners,
# the shotgun is expected by combat logic, but any valid prerequisite (as
# described in doc/design/regions.md or emitted by the in-game logic editor)
# can be used here.
#
#
#     cluster <number> <name> ;
#
# When scanning maps in this cluster, use <name> as the cluster name rather than
# the cluster or episode name reported by the WAD. <name> can contain anything
# except a semicolon, including whitespace, so this is legal:
#     cluster 66 Knee-Deep in the Dead;
# This is primarily useful in cases where the cluster/episode autodetection does
# not produce useful results, or it's desireable to abbreviate the results for
# Archipelago.
#
#
#     tag <actor> <name> ;
#
# Supply a tag (player-facing name) for the given actor. This will override the
# developer-provided tag the actor has, if any.
#
#
#     destroy-on-spawn <actor list> ;
#
# The listed actors will be scanned as normal, but will then be destroyed before
# they can execute any states. This is primarily useful for actors that randomly
# replace or delete themselves or spawn additional actors around them that should
# not be included in the scan.

#### General Doom/Heretic/Chex item categories ####
# GZAP has built in heuristics for item categorization: health and armour is
# considered "big" if it restores at least 100, "medium" if it restores at least
# 25 points, and "small" otherwise.
# Ammo is categorized similarly, except it's based on what % of your total ammo
# capacity is refilled, with backpacks considered "big" and anything that restores
# at least 20% of your capacity "medium".
# Unfortunately, there's no way to set that cutoff that properly categorizes
# everything in Doom or Heretic. So while the heuristics remain to support TCs,
# we use manual categorization for the Id games.
category small-ammo:
  Cell Clip RocketAmmo Shell
  BlasterAmmo CrossbowAmmo GoldWandAmmo MaceAmmo PhoenixRodAmmo SkullRodAmmo
  LargeZorchRecharge MiniZorchRecharge PhasingZorch PropulsorZorch;

category medium-ammo:
  CellPack ClipBox RocketBox ShellBox
  BlasterHefty CrossbowHefty GoldWandHefty MaceHefty PhoenixRodHefty SkullRodHefty
  LargeZorchPack MiniZorchPack PhasingZorchPack PropulsorZorchPack;

#### Doom 1/2 configuration ####

# Shotgunners and chaingunners imply a need for that weapon if weapon logic is
# turned on.
prereqs {
  actor ShotgunGuy: weapon/Shotgun/want;
  actor ChaingunGuy: weapon/Chaingun/want;
}

# Various powerups that cannot be automatically analyzed.
category big-armor-health: Megasphere;
category big-defence: InvulnerabilitySphere;
category medium-health-attack: Berserk;
category medium-tool: RadSuit;
category small-tool: Infrared;
category small-defence: BlurSphere;

# Doom 1/2 keys don't have tags defined! Names like "blue keycard" appear only
# in pickup messages and aren't associated with the actor itself.
tag BlueCard Blue Keycard;
tag YellowCard Yellow Keycard;
tag RedCard Red Keycard;
tag BlueSkull Blue Skull;
tag YellowSkull Yellow Skull;
tag RedSkull Red Skull;

# Ammo does have tags defined, but they overlap.
tag ClipBox Bullet Box;
tag ShellBox Shell Box;
tag RocketBox Rocket Box;
tag CellPack Cell Pack;

#### Heretic configuration ####

# Heretic has a bunch of tools/devices that need to be manually classified.
category big-defence: ArtiInvulnerability;
category medium-attack: ArtiTomeOfPower;
category small-defence: ArtiInvisibility;
category small-attack: ArtiEgg ArtiTimeBomb;
category small-tool: ArtiTorch ArtiTeleport;

# In Heretic, the Firemace is actually placed on the map as a MaceSpawner. When
# playing, there is a random chance for the Firemace to appear at each spawner.
# For rando purposes, we want to replace each spawner with a check, whether or
# not it got replaced when the scanner saw it.
# TODO: we might want to make this conditional in the same way BONSAIRC blocks
# are, so that the builtin RC can have different settings for different TCs?

# When scanning, consider MaceSpawners to be weapons rather than skipping them.
category weapon: MaceSpawner;

# When adding them to the pool, add Mace rather than MaceSpawner, and name the
# check based on Mace's tag rather than MaceSpawner's tag. This ensures that
# when the player finds one, they get an actual Firemace, rather than a spawner
# that might just do nothing when given to them.
typename Mace: MaceSpawner;

# Ignore any Maces that spawn entirely. They will neither be converted to checks
# nor added to the item pool.
category none: Mace;

# Also ignore the Wings of Wrath since they are often needed for level
# progression and the logic doesn't presently understand that.
category none: ArtiFly;

# Tags for overlapping ammo and armour names. Based on the Heretic pickup messages.
tag SilverShield Silver Shield;
tag GoldWandHefty Crystal Geode;
tag CrossbowHefty Quiver of Ethereal Arrows;
tag BlasterHefty Energy Orb;
tag PhoenixRodHefty Inferno Orb;
tag SkullRodHefty Greater Runes;
tag MaceHefty Pile of Mace Spheres;

#### Chex configuration ####

category medium-tool: SlimeProofSuit;
category small-tool: UltraGoggles;

# Overlapping ammo.
tag LargeZorchPack Large Zorcher Pack;
tag MiniZorchPack Mini Zorch Pack;
tag PhasingZorchPack Phasing Zorcher Pack;
tag PropulsorZorchPack Propulsor Pack;

# Chex is also missing names for these.
tag BlueFlemKey Blue Flemkey;
tag YellowFlemKey Yellow Flemkey;
tag RedFlemKey Red Flemkey;
