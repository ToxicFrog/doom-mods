#### Hedon Bloodrite configuration ####
require MAP01 f5a88e5eb33109c5ea424099f4625181;

cluster 13 Besieged; # maps 13-14-15: Besieged, Brazen Bull, and Deep Calls
cluster 18 Paradise Lost; # maps 18-19-20: Paradise Lost, Place Afoul, and Salt and Blood
cluster 21 Blood Rite; # maps 21-22: Blood Rite and Buried

# We need to do something here because Hedon is a mix of hublogic and non-hublogic maps.
# In particular, cluster 13 is a 3-map cluster that is completed by exiting from
# Besieged into MAP16 Port to Hell;
# cluster 18 is a 3-map cluster that is completed by exiting from Salt and Blood
# (I think) to MAP21 Blood Rite
# And cluster 21 is completed by traveling to map 22 (Buried) and killing the Baron.
# So really we want hublogic for those maps (and exits) and none of the others,
# which are standalone.
scanner {
  levels MAP01 MAP11;
  prune MAP31;
  recurse true;
  clusters true;
  # logic_flags use_hub_logic hub_logic_exits=MAP15,MAP20,MAP22;
}

# CustomInventory items.
# Same as SpikeMag, but different name and graphics.
category small-ammo: AmmoCultistSpike;

# Restores 3 AC.
category small-armor: PowerShard;

# Restores 20/40 HP.
category small-health: HealthGreenCrystal;
category medium-health: HealthGreenCrystalCouple;

# Custom tools.
category small-health-tool: InventoryVialOfHealing;
category powerup-tool:
  InventoryAmuletOfShadows InventoryBootsOfJourney InventoryBracerOfTheRevenant
  InventoryChokerofTheBeast InventoryElementalRing InventoryFixerGoggles
  InventoryPotionofHaste InventoryPotionOfMight InventoryPotionOfStoneskin
  InventoryRingOfTheRedMonk InventoryScrollAirWizardsEye
  InventoryScrollEarthNourish InventoryScrollFireInferno
  InventoryScrollFireMagmaBall InventorySentryGun InventoryTimeShard;

# Randomly either gives you:
# - heavy armour, might, power of the beast
# - light armour, health, timeshard, haste, and shadows
# - medium armour, stoneskin, elemental force
category medium-health-armor-powerup-tool: InventoryMysteryPotion;

# Guns. The potion launcher is special; "acid potion launcher" and "toxic potion
# launcher" are entirely distinct weapons internally. Both exist in various
# maps. The SpecialPotionBox is basically a reskinned acid launcher. the
# plain PotionLauncher gives you both when picked up.
# TODO: we may want to just treat the acid and toxic variants as "potion launcher"
# and collapse them into the merged weapon; or, alternatively, exclude the merged
# weapon and require the player to find them both separately.
typename PotionLauncherAcid: SpecialPotionBox;
category weapon: PotionLauncher;

