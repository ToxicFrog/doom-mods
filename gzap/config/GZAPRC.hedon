# Special handling for Bearzerker Mode. In addition to using its own spawnfilter
# (#6, which is mostly but not entirely the same as #5), it has a bunch of actor
# replacements. Axes are replaced with the bearzerker version (which lets you
# carry more for throwing but is otherwise identical), other weapons are replaced
# with nonfunctional versions of themselves, and most ammo is *randomly* either
# deleted or replaced with health, armour, or buff items.
# We handle this, at least for now, by scanning the Bearzerker random replacements
# as if they were their originals. This does mean that when playing Bearzerker
# AP will send you ammo, but when spawned in it will randomly turn into BZ items
# as normal, and you get the full set of small/medium checks (if enabled) rather
# than the random ~5% subset you would normally get.
# Things that we don't remap:
# - Axe is always replaced with BearzerkAxe, which stacks more
# - AmmoBullet and all other weapons are replaced with nothing
# - SpecialPotionBox is only ever spawned at runtime
typename AmmoBox: BearzerkAmmoBox;
typename AmmoBelt: BearzerkAmmoBelt;
typename AmmoCultistSpike: BearzerkAmmoCultistSpike;
typename Boltmag: BearzerkBoltmag;
typename FragfireCan: BearzerkFragfireCan;
typename FragfireCanHalf: BearzerkFragfireCanHalf;
typename PotionBoxAcid: BearzerkPotionBoxAcid;
typename PotionBoxToxic: BearzerkPotionBoxToxic;
typename SpikeMag: BearzerkSpikeMag;

# We also need to destroy the bearzerk spawners before their state machines run,
# as that will cause them to randomly be replaced with other items and/or deleted,
# and in the latter case that will confuse the scanner.
destroy-on-spawn
  BearzerkAmmoBelt
  BearzerkAmmoBox
  BearzerkAmmoCultistSpike
  BearzerkBoltmag
  BearzerkFragfireCan
  BearzerkFragfireCanHalf
  BearzerkPotionBoxAcid
  BearzerkPotionBoxToxic
  BearzerkSpikeMag
  ;
